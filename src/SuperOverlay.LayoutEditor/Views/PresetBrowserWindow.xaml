<Window x:Class="SuperOverlay.LayoutEditor.PresetBrowserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Load Preset"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Background="Transparent"
        AllowsTransparency="True"
        ShowInTaskbar="False">
    <Border Background="#F0122238"
            BorderBrush="#335071"
            BorderThickness="1"
            CornerRadius="16"
            Padding="20">
        <DockPanel Width="420" LastChildFill="True">
            <StackPanel DockPanel.Dock="Top">
                <TextBlock Text="Load Preset"
                           Foreground="#F2F5FA"
                           FontSize="18"
                           FontWeight="SemiBold"/>
                <TextBlock Margin="0,8,0,12"
                           Text="Choose a saved preset to place on the canvas."
                           Foreground="#A3AEC2"/>
            </StackPanel>
            <ListBox x:Name="PresetListBox"
                     MinHeight="220"
                     Background="#132238"
                     Foreground="#F2F5FA"
                     BorderBrush="#335071"
                     BorderThickness="1"/>
            <StackPanel DockPanel.Dock="Bottom"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,16,0,0">
                <Button Width="88"
                        Margin="0,0,8,0"
                        Content="Cancel"
                        Click="CancelButton_OnClick"/>
                <Button Width="88"
                        Content="Insert"
                        Click="InsertButton_OnClick"/>
            </StackPanel>
        </DockPanel>
    </Border>
</Window>
