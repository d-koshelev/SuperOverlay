<Window x:Class="SuperOverlay.LayoutEditor.LayoutNameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Save Layout"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Background="Transparent"
        AllowsTransparency="True"
        ShowInTaskbar="False">
    <Border Background="#F0122238"
            BorderBrush="#335071"
            BorderThickness="1"
            CornerRadius="16"
            Padding="20">
        <StackPanel Width="400">
            <TextBlock Text="Save Layout"
                       Foreground="#F2F5FA"
                       FontSize="18"
                       FontWeight="SemiBold"/>
            <TextBlock Margin="0,8,0,12"
                       Text="Enter a name for this layout."
                       Foreground="#A3AEC2"/>
            <TextBox x:Name="NameTextBox"
                     Background="#132238"
                     Foreground="#F2F5FA"
                     BorderBrush="#335071"
                     BorderThickness="1"
                     Padding="10,8"/>
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,16,0,0">
                <Button Width="88"
                        Margin="0,0,8,0"
                        Content="Cancel"
                        Click="CancelButton_OnClick"/>
                <Button Width="88"
                        Content="Save"
                        Click="SaveButton_OnClick"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
