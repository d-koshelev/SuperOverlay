<Window x:Class="SuperOverlay.LayoutEditor.MetricPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Metric"
        Width="320"
        Height="340"
        WindowStartupLocation="CenterOwner"
        Background="#0F1726">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Choose metric" Foreground="#F2F5FA" FontSize="16" FontWeight="SemiBold"/>
        <ListBox x:Name="MetricListBox"
                 Grid.Row="1"
                 Margin="0,12,0,0"
                 Background="#132238"
                 Foreground="#F2F5FA"
                 BorderBrush="#26405F"
                 BorderThickness="1"
                 MouseDoubleClick="MetricListBox_OnMouseDoubleClick"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel" Width="88" Margin="0,0,8,0" Click="CancelButton_OnClick"/>
            <Button Content="Select" Width="88" Click="SelectButton_OnClick"/>
        </StackPanel>
    </Grid>
</Window>
