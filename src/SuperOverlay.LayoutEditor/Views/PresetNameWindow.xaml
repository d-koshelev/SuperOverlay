<Window x:Class="SuperOverlay.LayoutEditor.PresetNameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Save Preset"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Background="Transparent"
        AllowsTransparency="True"
        ShowInTaskbar="False">
    <Border Background="#F0122238"
            BorderBrush="#335071"
            BorderThickness="1"
            CornerRadius="16"
            Padding="20">
        <StackPanel Width="360">
            <TextBlock Text="Save as Preset"
                       Foreground="#F2F5FA"
                       FontSize="18"
                       FontWeight="SemiBold"/>
            <TextBlock Margin="0,12,0,6"
                       Text="Preset name"
                       Foreground="#A3AEC2"/>
            <TextBox x:Name="NameTextBox"
                     Padding="10,8"
                     Background="#132238"
                     Foreground="#F2F5FA"
                     BorderBrush="#335071"
                     BorderThickness="1"/>
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,18,0,0">
                <Button Width="88"
                        Margin="0,0,8,0"
                        Content="Cancel"
                        Click="CancelButton_OnClick"/>
                <Button Width="88"
                        Content="Save"
                        Click="SaveButton_OnClick"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
