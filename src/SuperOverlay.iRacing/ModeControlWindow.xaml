<Window x:Class="SuperOverlay.iRacing.ModeControlWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SuperOverlay Mode"
        Width="320"
        Height="140"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        Topmost="False">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Overlay Mode" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Left">
            <Button x:Name="RaceButton" Content="RACE" Width="120" Height="36" Click="RaceButton_OnClick"/>
            <Button x:Name="EditButton" Content="EDIT" Width="120" Height="36" Margin="12,0,0,0" Click="EditButton_OnClick"/>
        </StackPanel>
    </Grid>
</Window>
