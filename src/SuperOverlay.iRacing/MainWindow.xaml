<Window x:Class="SuperOverlay.iRacing.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Overlay"
        Width="520"
        Height="380"
        WindowStyle="None"
        Background="Black"
        Topmost="True">

    <DockPanel>
        <Border x:Name="EditorBar"
                DockPanel.Dock="Top"
                Background="#CC1C1C1C"
                Padding="8"
                MouseLeftButtonDown="EditorBar_MouseLeftButtonDown">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Item"
                           Foreground="White"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>

                <ComboBox x:Name="ItemComboBox"
                          Width="220"
                          DisplayMemberPath="DisplayText"
                          SelectionChanged="ItemComboBox_OnSelectionChanged"/>

                <ToggleButton x:Name="SnapToggleButton"
                              Content="Snap: On"
                              IsChecked="True"
                              Margin="12,0,0,0"
                              Padding="10,4"
                              Checked="SnapToggleButton_OnChecked"
                              Unchecked="SnapToggleButton_OnUnchecked"/>

                <Button Content="←"
                        Width="32"
                        Margin="12,0,0,0"
                        Click="MoveLeft_OnClick"/>

                <Button Content="↑"
                        Width="32"
                        Margin="4,0,0,0"
                        Click="MoveUp_OnClick"/>

                <Button Content="↓"
                        Width="32"
                        Margin="4,0,0,0"
                        Click="MoveDown_OnClick"/>

                <Button Content="→"
                        Width="32"
                        Margin="4,0,0,0"
                        Click="MoveRight_OnClick"/>

                <Button Content="Save"
                        Margin="12,0,0,0"
                        Click="SaveLayout_OnClick"/>

                <Button Content="Reload"
                        Margin="4,0,0,0"
                        Click="ReloadLayout_OnClick"/>
            </StackPanel>
        </Border>

        <Grid Background="#11000000">
            <Grid x:Name="RootGrid"
                  Background="Transparent"
                  PreviewMouseLeftButtonDown="RootGrid_OnMouseLeftButtonDown"
                  MouseMove="RootGrid_OnMouseMove"
                  MouseLeftButtonUp="RootGrid_OnMouseLeftButtonUp"/>

            <Border x:Name="VerticalGuide"
                    Width="1"
                    Background="#FF60A5FA"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Stretch"
                    Visibility="Collapsed"
                    IsHitTestVisible="False"/>

            <Border x:Name="HorizontalGuide"
                    Height="1"
                    Background="#FF60A5FA"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Top"
                    Visibility="Collapsed"
                    IsHitTestVisible="False"/>
        </Grid>
    </DockPanel>

</Window>