<Window x:Class="SuperOverlay.iRacing.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Overlay"
        Width="940"
        Height="500"
        WindowStyle="None"
        Background="#FFF3F5F7"
        Topmost="True"
        Focusable="True"
        KeyDown="Window_OnKeyDown">

    <DockPanel>
        <Border x:Name="EditorBar"
                DockPanel.Dock="Top"
                Background="#FFF7F8FA"
                Padding="8"
                MouseLeftButtonDown="EditorBar_MouseLeftButtonDown">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Add"
                               Foreground="#FF1F2937"
                               VerticalAlignment="Center"
                               Margin="12,0,8,0"/>

                    <ComboBox x:Name="CatalogComboBox"
                              Width="180"
                              DisplayMemberPath="DisplayName"/>

                    <Button Content="Add"
                            Margin="8,0,0,0"
                            Click="AddSelectedCatalogItem_OnClick"/>

                    <ToggleButton x:Name="SnapToggleButton"
                                  Content="Snap: On"
                                  IsChecked="True"
                                  Margin="12,0,0,0"
                                  Padding="10,4"
                                  Checked="SnapToggleButton_OnChecked"
                                  Unchecked="SnapToggleButton_OnUnchecked"/>

                    <Button Content="Save"
                            Margin="12,0,0,0"
                            Click="SaveLayout_OnClick"/>

                    <Button Content="Reload"
                            Margin="4,0,0,0"
                            Click="ReloadLayout_OnClick"/>
                </StackPanel>

                <TextBlock Margin="12,8,0,0"
                           Foreground="#FF6B7280"
                           FontSize="11"
                           TextWrapping="Wrap">
                    <Run Text="Shortcuts: "/>
                    <Run Text="Del delete"/>
                    <Run Text=" • Ctrl+C copy"/>
                    <Run Text=" • Ctrl+V paste"/>
                    <Run Text=" • Ctrl+D duplicate"/>
                    <Run Text=" • Ctrl+G group"/>
                    <Run Text=" • Ctrl+Shift+G ungroup"/>
                    <Run Text=" • Ctrl+L lock / Ctrl+Shift+L unlock"/>
                    <Run Text=" • [ / ] reorder"/>
                    <Run Text=" • Shift+[ / Shift+] back/front"/>
                    <Run Text=" • Arrows move"/>
                    <Run Text=" • Shift+Arrows ×5"/>
                    <Run Text=" • Ctrl+S save"/>
                    <Run Text=" • F5 reload"/>
                    <Run Text=" • Esc clear"/>
                    <Run Text=" • Alt bypass snap"/>
                    <LineBreak/>
                    <Run Text="Mouse: Ctrl+click multi-select, drag on empty canvas for box select, right click for actions, drag selected items, resize from the handle."/>
                </TextBlock>
            </StackPanel>
        </Border>

        <Grid Background="#FFF3F5F7">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="270"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Border Margin="12"
                        CornerRadius="10"
                        BorderBrush="#FFDCE2E8"
                        BorderThickness="1"
                        IsHitTestVisible="False">
                    <Border.Background>
                        <DrawingBrush TileMode="Tile"
                                      Viewport="0,0,24,24"
                                      ViewportUnits="Absolute"
                                      Stretch="None">
                            <DrawingBrush.Drawing>
                                <DrawingGroup>
                                    <GeometryDrawing Brush="#FFF9FAFB"
                                                     Geometry="M0,0 H24 V24 H0 Z"/>
                                    <GeometryDrawing>
                                        <GeometryDrawing.Pen>
                                            <Pen Brush="#0D334155" Thickness="1"/>
                                        </GeometryDrawing.Pen>
                                        <GeometryDrawing.Geometry>
                                            <GeometryGroup>
                                                <LineGeometry StartPoint="24,0" EndPoint="24,24"/>
                                                <LineGeometry StartPoint="0,24" EndPoint="24,24"/>
                                            </GeometryGroup>
                                        </GeometryDrawing.Geometry>
                                    </GeometryDrawing>
                                    <GeometryDrawing>
                                        <GeometryDrawing.Brush>
                                            <SolidColorBrush Color="#12334155"/>
                                        </GeometryDrawing.Brush>
                                        <GeometryDrawing.Geometry>
                                            <EllipseGeometry Center="24,24" RadiusX="1.25" RadiusY="1.25"/>
                                        </GeometryDrawing.Geometry>
                                    </GeometryDrawing>
                                </DrawingGroup>
                            </DrawingBrush.Drawing>
                        </DrawingBrush>
                    </Border.Background>
                </Border>

                <Grid x:Name="RootGrid"
                      Margin="12"
                      ClipToBounds="True"
                      Background="Transparent"
                      PreviewMouseLeftButtonDown="RootGrid_OnMouseLeftButtonDown"
                      PreviewMouseRightButtonDown="RootGrid_OnPreviewMouseRightButtonDown"
                      ContextMenuOpening="RootGrid_OnContextMenuOpening"
                      MouseMove="RootGrid_OnMouseMove"
                      MouseLeftButtonUp="RootGrid_OnMouseLeftButtonUp">
                    <Grid.ContextMenu>
                        <ContextMenu x:Name="CanvasContextMenu">
                            <MenuItem x:Name="CopyMenuItem" Header="Copy" Click="CopySelected_OnClick"/>
                            <MenuItem x:Name="PasteMenuItem" Header="Paste" Click="PasteClipboard_OnClick"/>
                            <MenuItem x:Name="DuplicateMenuItem" Header="Duplicate" Click="DuplicateSelected_OnClick"/>
                            <MenuItem x:Name="DeleteMenuItem" Header="Delete" Click="DeleteSelected_OnClick"/>
                            <Separator/>
                            <MenuItem x:Name="GroupSelectedMenuItem" Header="Group Selected" Click="GroupSelected_OnClick"/>
                            <MenuItem x:Name="UngroupSelectedMenuItem" Header="Ungroup Selected" Click="UngroupSelected_OnClick"/>
                            <Separator/>
                            <MenuItem x:Name="LockSelectedMenuItem" Header="Lock Selected" Click="LockSelected_OnClick"/>
                            <MenuItem x:Name="UnlockSelectedMenuItem" Header="Unlock Selected" Click="UnlockSelected_OnClick"/>
                            <Separator/>
                            <MenuItem x:Name="BringForwardMenuItem" Header="Bring Forward" Click="BringForward_OnClick"/>
                            <MenuItem x:Name="SendBackwardMenuItem" Header="Send Backward" Click="SendBackward_OnClick"/>
                            <MenuItem x:Name="BringToFrontMenuItem" Header="Bring To Front" Click="BringToFront_OnClick"/>
                            <MenuItem x:Name="SendToBackMenuItem" Header="Send To Back" Click="SendToBack_OnClick"/>
                        </ContextMenu>
                    </Grid.ContextMenu>
                </Grid>

                <Border x:Name="SelectionMarquee"
                        BorderBrush="#FF60A5FA"
                        BorderThickness="2"
                        Background="#2260A5FA"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Visibility="Collapsed"
                        IsHitTestVisible="False"/>

                <Border x:Name="VerticalGuide"
                        Width="1"
                        Background="#FF60A5FA"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Stretch"
                        Visibility="Collapsed"
                        IsHitTestVisible="False"/>

                <Border x:Name="HorizontalGuide"
                        Height="1"
                        Background="#FF60A5FA"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Top"
                        Visibility="Collapsed"
                        IsHitTestVisible="False"/>
            </Grid>

            <Border Grid.Column="1"
                    Background="#FFFCFCFD"
                    BorderBrush="#FFE5E7EB"
                    BorderThickness="1,0,0,0"
                    Padding="12">
                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock Text="Properties"
                                   Foreground="#FF1F2937"
                                   FontSize="16"
                                   FontWeight="SemiBold"/>

                        <TextBlock x:Name="PropertiesHintTextBlock"
                                   Margin="0,8,0,12"
                                   Foreground="#FF6B7280"
                                   Text="Select an item to edit its properties. Multi-select keeps one primary item here."
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  CanContentScroll="True">
                        <StackPanel x:Name="PropertiesPanel"
                                    IsEnabled="False">
                        <TextBlock Text="Widget"
                                   Foreground="#FF6B7280"/>
                        <TextBlock x:Name="SelectedWidgetNameTextBlock"
                                   Margin="0,2,0,0"
                                   Foreground="#FF1F2937"
                                   FontWeight="SemiBold"/>
                        <TextBlock x:Name="SelectedWidgetMetaTextBlock"
                                   Margin="0,2,0,12"
                                   Foreground="#FF6B7280"
                                   FontSize="11"
                                   TextWrapping="Wrap"/>

                        <UniformGrid Columns="2" Margin="0,0,0,8">
                            <StackPanel Margin="0,0,6,0">
                                <TextBlock Text="X" Foreground="#FF6B7280"/>
                                <TextBox x:Name="XTextBox" Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel Margin="6,0,0,0">
                                <TextBlock Text="Y" Foreground="#FF6B7280"/>
                                <TextBox x:Name="YTextBox" Margin="0,4,0,0"/>
                            </StackPanel>
                        </UniformGrid>

                        <UniformGrid Columns="2" Margin="0,0,0,8">
                            <StackPanel Margin="0,0,6,0">
                                <TextBlock Text="Width" Foreground="#FF6B7280"/>
                                <TextBox x:Name="WidthTextBox" Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel Margin="6,0,0,0">
                                <TextBlock Text="Height" Foreground="#FF6B7280"/>
                                <TextBox x:Name="HeightTextBox" Margin="0,4,0,0"/>
                            </StackPanel>
                        </UniformGrid>

                        <UniformGrid Columns="2" Margin="0,0,0,8">
                            <StackPanel Margin="0,0,6,0">
                                <TextBlock Text="Z-Index" Foreground="#FF6B7280"/>
                                <TextBox x:Name="ZIndexTextBox" Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel Margin="6,20,0,0">
                                <CheckBox x:Name="LockedCheckBox"
                                          Content="Locked"
                                          Foreground="#FF1F2937"/>
                            </StackPanel>
                        </UniformGrid>

                        <StackPanel x:Name="CommonCornerSettingsPanel"
                                    Margin="0,12,0,0"
                                    Visibility="Collapsed">
                            <Separator Margin="0,0,0,12"/>
                            <TextBlock Text="Widget corners"
                                       Foreground="#FF1F2937"
                                       FontWeight="SemiBold"/>

                            <UniformGrid Columns="2" Margin="0,8,0,0">
                                <StackPanel Margin="0,0,6,0">
                                    <TextBlock Text="Top-left radius" Foreground="#FF6B7280"/>
                                    <TextBox x:Name="CommonCornerTopLeftTextBox" Margin="0,4,0,0"/>
                                </StackPanel>
                                <StackPanel Margin="6,0,0,0">
                                    <TextBlock Text="Top-right radius" Foreground="#FF6B7280"/>
                                    <TextBox x:Name="CommonCornerTopRightTextBox" Margin="0,4,0,0"/>
                                </StackPanel>
                            </UniformGrid>

                            <UniformGrid Columns="2" Margin="0,8,0,0">
                                <StackPanel Margin="0,0,6,0">
                                    <TextBlock Text="Bottom-right radius" Foreground="#FF6B7280"/>
                                    <TextBox x:Name="CommonCornerBottomRightTextBox" Margin="0,4,0,0"/>
                                </StackPanel>
                                <StackPanel Margin="6,0,0,0">
                                    <TextBlock Text="Bottom-left radius" Foreground="#FF6B7280"/>
                                    <TextBox x:Name="CommonCornerBottomLeftTextBox" Margin="0,4,0,0"/>
                                </StackPanel>
                            </UniformGrid>

                            <TextBlock Margin="0,8,0,0"
                                       Foreground="#FF6B7280"
                                       FontSize="11"
                                       Text="Corner radii are applied to the selected widget. Default is 0 so widgets can glue together without gaps."/>
                        </StackPanel>

                        <StackPanel x:Name="ShiftLedSettingsPanel"
                                    Margin="0,12,0,0"
                                    Visibility="Collapsed">
                            <Separator Margin="0,0,0,12"/>
                            <TextBlock Text="LED Shift Panel"
                                       Foreground="#FF1F2937"
                                       FontWeight="SemiBold"/>

                            <UniformGrid Columns="2" Margin="0,8,0,0">
                                <StackPanel Margin="0,0,6,0">
                                    <TextBlock Text="LED count" Foreground="#FF6B7280"/>
                                    <TextBox x:Name="ShiftLedCountTextBox" Margin="0,4,0,0"/>
                                </StackPanel>
                                <StackPanel Margin="6,20,0,0">
                                    <CheckBox x:Name="ShiftUsePerLedColorsCheckBox"
                                              Content="Use per-LED colors"
                                              Foreground="#FF1F2937"/>
                                </StackPanel>
                            </UniformGrid>

                            <CheckBox x:Name="ShiftShowBackgroundCheckBox"
                                      Margin="0,8,0,0"
                                      Content="Show background"
                                      Foreground="#FF1F2937"/>

                            <StackPanel Margin="0,8,0,0">
                                <TextBlock Text="Background color" Foreground="#FF6B7280"/>
                                <DockPanel Margin="0,4,0,0" LastChildFill="True">
                                    <Button Content="Pick"
                                            Width="44"
                                            Margin="8,0,0,0"
                                            DockPanel.Dock="Right"
                                            Click="PickShiftBackgroundColor_OnClick"/>
                                    <TextBox x:Name="ShiftBackgroundColorTextBox"/>
                                </DockPanel>
                            </StackPanel>

                            <StackPanel Margin="0,8,0,0">
                                <TextBlock Text="LED off color" Foreground="#FF6B7280"/>
                                <DockPanel Margin="0,4,0,0" LastChildFill="True">
                                    <Button Content="Pick"
                                            Width="44"
                                            Margin="8,0,0,0"
                                            DockPanel.Dock="Right"
                                            Click="PickShiftOffColor_OnClick"/>
                                    <TextBox x:Name="ShiftOffColorTextBox"/>
                                </DockPanel>
                            </StackPanel>

                            <StackPanel Margin="0,8,0,0">
                                <TextBlock Text="Fallback LED on color" Foreground="#FF6B7280"/>
                                <DockPanel Margin="0,4,0,0" LastChildFill="True">
                                    <Button Content="Pick"
                                            Width="44"
                                            Margin="8,0,0,0"
                                            DockPanel.Dock="Right"
                                            Click="PickShiftOnColor_OnClick"/>
                                    <TextBox x:Name="ShiftOnColorTextBox"/>
                                </DockPanel>
                            </StackPanel>

                            <StackPanel Margin="0,8,0,0">
                                <TextBlock Text="Per-LED colors" Foreground="#FF6B7280"/>
                                <TextBox x:Name="ShiftOnColorsTextBox"
                                         Margin="0,4,0,0"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         MinHeight="74"
                                         VerticalScrollBarVisibility="Auto"/>
                            </StackPanel>

                            <TextBlock Margin="0,8,0,0"
                                       Foreground="#FF6B7280"
                                       FontSize="11"
                                       Text="Use WPF color values like #20262E or #E6111827. Per-LED colors can be comma, semicolon or line separated. Turn off per-LED colors to use one shared on-color for all lamps."/>
                        </StackPanel>

                        <StackPanel x:Name="DecorativePanelSettingsPanel"
                                    Margin="0,12,0,0"
                                    Visibility="Collapsed">
                            <Separator Margin="0,0,0,12"/>
                            <TextBlock Text="Decorative Panel"
                                       Foreground="#FF1F2937"
                                       FontWeight="SemiBold"/>

                            <StackPanel Margin="0,8,0,0">
                                <TextBlock Text="Background color" Foreground="#FF6B7280"/>
                                <DockPanel Margin="0,4,0,0" LastChildFill="True">
                                    <Button Content="Pick"
                                            Width="44"
                                            Margin="8,0,0,0"
                                            DockPanel.Dock="Right"
                                            Click="PickDecorativeBackgroundColor_OnClick"/>
                                    <TextBox x:Name="DecorativeBackgroundColorTextBox"/>
                                </DockPanel>
                            </StackPanel>

                            <StackPanel Margin="0,8,0,0">
                                <TextBlock Text="Opacity" Foreground="#FF6B7280"/>
                                <TextBox x:Name="DecorativeOpacityTextBox"
                                         Margin="0,4,0,0"/>
                            </StackPanel>

                            <TextBlock Margin="0,8,0,0"
                                       Foreground="#FF6B7280"
                                       FontSize="11"
                                       Text="Decorative panel uses a WPF color value like #20262E or #CC1F2937. Opacity uses a value from 0 to 1."/>
                        </StackPanel>

                        <Button Content="Apply"
                                Margin="0,12,0,0"
                                Padding="10,6"
                                Click="ApplyProperties_OnClick"/>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>

</Window>
