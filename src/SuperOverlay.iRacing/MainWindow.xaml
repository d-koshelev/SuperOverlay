<Window x:Class="SuperOverlay.iRacing.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Overlay"
        Width="760"
        Height="420"
        WindowStyle="None"
        Background="#FFF3F4F6"
        Topmost="True">

    <DockPanel>
        <Border x:Name="EditorBar"
                DockPanel.Dock="Top"
                Background="#FFE5E7EB"
                BorderBrush="#FFD1D5DB"
                BorderThickness="0,0,0,1"
                Padding="8"
                MouseLeftButtonDown="EditorBar_MouseLeftButtonDown">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Editor"
                           Foreground="#FF111827"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="0,0,14,0"/>

                <TextBlock Text="Catalog"
                           Foreground="#FF374151"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>

                <ComboBox x:Name="CatalogComboBox"
                          Width="180"
                          DisplayMemberPath="DisplayName"/>

                <Button Content="Add"
                        Margin="8,0,14,0"
                        Padding="10,4"
                        Click="AddItem_OnClick"/>

                <TextBlock Text="Selected"
                           Foreground="#FF374151"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>

                <ComboBox x:Name="ItemComboBox"
                          Width="220"
                          DisplayMemberPath="DisplayText"
                          SelectionChanged="ItemComboBox_OnSelectionChanged"/>

                <Button Content="←"
                        Width="32"
                        Margin="12,0,0,0"
                        Click="MoveLeft_OnClick"/>

                <Button Content="↑"
                        Width="32"
                        Margin="4,0,0,0"
                        Click="MoveUp_OnClick"/>

                <Button Content="↓"
                        Width="32"
                        Margin="4,0,0,0"
                        Click="MoveDown_OnClick"/>

                <Button Content="→"
                        Width="32"
                        Margin="4,0,0,0"
                        Click="MoveRight_OnClick"/>

                <Button Content="Save"
                        Margin="12,0,0,0"
                        Padding="10,4"
                        Click="SaveLayout_OnClick"/>

                <Button Content="Reload"
                        Margin="4,0,0,0"
                        Padding="10,4"
                        Click="ReloadLayout_OnClick"/>
            </StackPanel>
        </Border>

        <Border Background="#FFF9FAFB">
            <Grid x:Name="RootGrid"
                  Background="Transparent"
                  MouseLeftButtonDown="RootGrid_OnMouseLeftButtonDown"
                  MouseMove="RootGrid_OnMouseMove"
                  MouseLeftButtonUp="RootGrid_OnMouseLeftButtonUp"/>
        </Border>
    </DockPanel>

</Window>
