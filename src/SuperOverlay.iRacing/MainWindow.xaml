<Window x:Class="SuperOverlay.iRacing.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Overlay"
        Width="520"
        Height="380"
        WindowStyle="None"
        Background="Black"
        Topmost="True">

    <DockPanel>
        <Border DockPanel.Dock="Top"
                Background="#CC1C1C1C"
                Padding="8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Item"
                           Foreground="White"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>

                <ComboBox x:Name="ItemComboBox"
                          Width="220"
                          DisplayMemberPath="DisplayText"
                          SelectionChanged="ItemComboBox_OnSelectionChanged"/>

                <Button Content="←"
                        Width="32"
                        Margin="12,0,0,0"
                        Click="MoveLeft_OnClick"/>

                <Button Content="↑"
                        Width="32"
                        Margin="4,0,0,0"
                        Click="MoveUp_OnClick"/>

                <Button Content="↓"
                        Width="32"
                        Margin="4,0,0,0"
                        Click="MoveDown_OnClick"/>

                <Button Content="→"
                        Width="32"
                        Margin="4,0,0,0"
                        Click="MoveRight_OnClick"/>

                <Button Content="Save"
                        Margin="12,0,0,0"
                        Click="SaveLayout_OnClick"/>

                <Button Content="Reload"
                        Margin="4,0,0,0"
                        Click="ReloadLayout_OnClick"/>
            </StackPanel>
        </Border>

        <Grid x:Name="RootGrid"/>
    </DockPanel>

</Window>
