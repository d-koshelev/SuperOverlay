<Window x:Class="SuperOverlay.iRacing.Editor.PanelPresetSaveWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Save Panel Preset"
        Width="520"
        Height="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FFF7F8FA">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Save Panel Preset"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Foreground="#FF1F2937"/>

        <TextBlock Grid.Row="1"
                   Margin="0,8,0,12"
                   TextWrapping="Wrap"
                   Foreground="#FF6B7280"
                   Text="Name and categorize this panel preset before adding it to the library."/>

        <Border Grid.Row="2"
                BorderBrush="#FFDCE2E8"
                BorderThickness="1"
                CornerRadius="10"
                Background="White"
                Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock VerticalAlignment="Center" Foreground="#FF374151" Text="Name"/>
                <TextBox x:Name="NameTextBox"
                         Grid.Column="1"
                         MinWidth="240"
                         Padding="8,6"
                         TextChanged="Inputs_OnChanged"/>

                <TextBlock Grid.Row="1" VerticalAlignment="Center" Foreground="#FF374151" Text="Category" Margin="0,12,0,0"/>
                <TextBox x:Name="CategoryTextBox"
                         Grid.Row="1"
                         Grid.Column="1"
                         Margin="0,12,0,0"
                         Padding="8,6"
                         TextChanged="Inputs_OnChanged"/>

                <TextBlock Grid.Row="2" VerticalAlignment="Center" Foreground="#FF374151" Text="Directory" Margin="0,12,0,0"/>
                <TextBlock x:Name="DirectoryTextBlock"
                           Grid.Row="2"
                           Grid.Column="1"
                           Margin="0,12,0,0"
                           Foreground="#FF6B7280"
                           TextWrapping="Wrap"/>

                <TextBlock Grid.Row="3" VerticalAlignment="Center" Foreground="#FF374151" Text="File" Margin="0,12,0,0"/>
                <TextBlock x:Name="FilePathTextBlock"
                           Grid.Row="3"
                           Grid.Column="1"
                           Margin="0,12,0,0"
                           Foreground="#FF111827"
                           TextWrapping="Wrap"/>

                <Border Grid.Row="4"
                        Grid.ColumnSpan="2"
                        Margin="0,14,0,0"
                        Padding="10"
                        CornerRadius="8"
                        Background="#FFF9FAFB"
                        BorderBrush="#FFE5E7EB"
                        BorderThickness="1">
                    <TextBlock x:Name="HintTextBlock"
                               Foreground="#FF6B7280"
                               TextWrapping="Wrap"
                               Text="The file name is generated automatically from the panel name."/>
                </Border>

                <TextBlock x:Name="ValidationTextBlock"
                           Grid.Row="5"
                           Grid.ColumnSpan="2"
                           Margin="0,12,0,0"
                           Foreground="#FFB91C1C"
                           Visibility="Collapsed"
                           TextWrapping="Wrap"/>
            </Grid>
        </Border>

        <DockPanel Grid.Row="3" Margin="0,12,0,0">
            <TextBlock VerticalAlignment="Center" Foreground="#FF6B7280" Text="Panel preset will be stored in the current layout library."/>
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <Button Content="Cancel" Width="84" Margin="0,0,8,0" IsCancel="True"/>
                <Button x:Name="SaveButton" Content="Save" Width="84" IsDefault="True" Click="Save_OnClick"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
