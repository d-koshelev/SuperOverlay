<Window x:Class="SuperOverlay.iRacing.Editor.PanelPresetBrowserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Panel Presets"
        Width="560"
        Height="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#FFF7F8FA">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Panel Presets"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Foreground="#FF1F2937"/>

        <TextBlock Grid.Row="1"
                   Margin="0,8,0,12"
                   TextWrapping="Wrap"
                   Foreground="#FF6B7280"
                   Text="Choose a saved panel preset to insert into the current layout."/>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>

            <Border BorderBrush="#FFDCE2E8"
                    BorderThickness="1"
                    CornerRadius="10"
                    Background="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ListBox x:Name="PresetListBox"
                         Margin="8"
                         BorderThickness="0"
                         MouseDoubleClick="PresetListBox_OnMouseDoubleClick"
                         SelectionChanged="PresetListBox_OnSelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10" Margin="0,0,0,6" CornerRadius="8" Background="#FFF9FAFB" BorderBrush="#FFE5E7EB" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="#FF111827"/>
                                        <TextBlock Margin="0,4,0,0" Foreground="#FF6B7280" Text="{Binding CategoryLine}"/>
                                        <TextBlock Margin="0,2,0,0" Foreground="#FF9CA3AF" FontSize="11" Text="{Binding Path}" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <Border Grid.Column="1" Padding="8,4" CornerRadius="999" Background="#FFEEF2FF" VerticalAlignment="Top">
                                        <TextBlock Text="{Binding SizeLine}" Foreground="#FF4338CA" FontSize="11" FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                    <TextBlock x:Name="EmptyStateTextBlock"
                               Grid.Row="1"
                               Margin="12,0,12,12"
                               Foreground="#FF9CA3AF"
                               Visibility="Collapsed"
                               Text="No panel presets found in this layout library yet."/>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Margin="12,0,0,0"
                    BorderBrush="#FFDCE2E8"
                    BorderThickness="1"
                    CornerRadius="10"
                    Background="White"
                    Padding="12">
                <StackPanel>
                    <TextBlock Text="Preset Summary" FontWeight="SemiBold" Foreground="#FF111827"/>
                    <TextBlock x:Name="SummaryNameTextBlock" Margin="0,10,0,0" FontSize="15" FontWeight="SemiBold" Foreground="#FF111827" Text="Select a preset"/>
                    <TextBlock x:Name="SummaryCategoryTextBlock" Margin="0,8,0,0" Foreground="#FF6B7280" Text="Category: —"/>
                    <TextBlock x:Name="SummarySizeTextBlock" Margin="0,4,0,0" Foreground="#FF6B7280" Text="Size: —"/>
                    <TextBlock x:Name="SummaryItemCountTextBlock" Margin="0,4,0,0" Foreground="#FF6B7280" Text="Widgets: —"/>
                    <TextBlock x:Name="SummaryLinkCountTextBlock" Margin="0,4,0,0" Foreground="#FF6B7280" Text="Links: —"/>
                    <TextBlock x:Name="SummaryPathTextBlock" Margin="0,10,0,0" Foreground="#FF9CA3AF" TextWrapping="Wrap" Text=""/>
                </StackPanel>
            </Border>
        </Grid>

        <DockPanel Grid.Row="3" Margin="0,12,0,0">
            <TextBlock x:Name="LibraryPathTextBlock"
                       VerticalAlignment="Center"
                       Foreground="#FF6B7280"
                       TextTrimming="CharacterEllipsis"/>
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <Button Content="Refresh" Width="84" Margin="0,0,8,0" Click="Refresh_OnClick"/>
                <Button x:Name="DeleteButton" Content="Delete" Width="84" Margin="0,0,8,0" Click="Delete_OnClick"/>
                <Button Content="Cancel" Width="84" Margin="0,0,8,0" IsCancel="True"/>
                <Button x:Name="OpenButton" Content="Open" Width="84" Margin="0,0,8,0" Click="Open_OnClick"/>
                <Button x:Name="InsertButton" Content="Insert" Width="84" IsDefault="True" Click="Insert_OnClick"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
